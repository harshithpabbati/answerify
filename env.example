NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
NEXT_PUBLIC_BASE_URL=http://localhost:3000
RESEND_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Cloudflare AI Gateway (optional)
# Set these to route AI requests through Cloudflare's AI Gateway for logging
# and observability. See https://developers.cloudflare.com/ai-gateway/
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_GATEWAY_NAME=
CF_AIG_TOKEN=

# Savoir sandbox tools (optional)
# Set these to give the AI model access to sandboxed bash tools for deep-dive
# exploration when the embedding context alone is insufficient.
# SAVOIR_API_URL is the base URL of your deployed Savoir knowledge-agent instance.
# See https://github.com/vercel-labs/knowledge-agent-template for deployment instructions.
SAVOIR_API_URL=
SAVOIR_API_KEY=
